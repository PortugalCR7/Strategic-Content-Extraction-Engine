{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "target": "ES2022",
        "lib": [
            "ES2022",
            "DOM",
            "DOM.Iterable"
        ],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "jsx": "preserve",
        "noEmit": true,
        "plugins": [
            {
                "name": "next"
            }
        ],
        "paths": {
            "@/*": [
                "./*"
            ]
        },
        "allowJs": true,
        "incremental": true
    },
    "include": [
        "next-env.d.ts",
        "next.config.js",
        "app",
        "components",
        "lib",
        ".next/types/**/*.ts"
    ],
    "exclude": [
        ".next",
        "out",
        "node_modules"
    ]
}